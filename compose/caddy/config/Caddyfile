# File structure: https://caddyserver.com/docs/caddyfile/concepts#structure
# -------------------

### --------------
### GLOBAL OPTIONS
### --------------
{
	# debug  # uncomment to enable debug mode
	servers {
		# trusted_proxies docs: # https://caddyserver.com/docs/caddyfile/options#trusted-proxies
		# caddy-cloudflare-ip docs: https://github.com/WeidiDeng/caddy-cloudflare-ip
		trusted_proxies cloudflare {
			interval 12h
			timeout 15s
		}
	}
	dynamic_dns {
		# caddy-dynamicdns docs: https://github.com/mholt/caddy-dynamicdns
		provider cloudflare {env.CLOUDFLARE_API_TOKEN} # caddy-dns/cloudflare docs: https://github.com/caddy-dns/cloudflare
		domains {
			# routes the below domains
			mattdies.com www minecraft
		}
		versions ipv4 # disables IPv6
		dynamic_domains # searches the Caddyfile for new domains, and manages them
	}
}

### --------
### SNIPPETS
### --------
(use_authelia) {
	# forwards any requests to the route using the snippet to authelia for login before access
	forward_auth authelia:9091 {
		uri /api/authz/forward-auth
		copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
	}
}

(local_network_only) {
	# restricts access to any route using the snippet to local traffic only by responding with a 403
	@external not remote_ip 10.144.88.0/24 172.19.0.0/16
	respond @external 403 {
		close
	}
}

(cloudflare_dns) {
	# routes an application with cloudflare
	# this could *probably* be a global setting, but just in case we don't want something publicly routed, it's a snippet
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
		resolvers 1.1.1.1 1.1.1.2
	}
}

(log_for_app) {
	# logs an app to the caddy logfiles for the route based on the args
	log {
		output file /var/log/caddy/{args[0]}.log
	}
}

# caddy-ratelimit docs: https://github.com/mholt/caddy-ratelimit?tab=readme-ov-file#examples
(rate_limit_api) {
	# rate limits a given path with some opinionated measures
	rate_limit {
		distributed
		zone api_zone {
			match {
				path {args[0]} # Use the argument for the snippet to match the path
			}
			key {remote_host} # Use the client's IP address as the key
			window 5s # Rate limiting window (default is 1 minute)
			events 200 # Allow up to 200 requests per window
		}
		log_key
	}
}

### ----------
### SERVE APPS
### ----------
# ------------------------------------------------
# authentication

auth.mattdies.com {
	import local_network_only
	import cloudflare_dns
	import log_for_app "authelia"
	reverse_proxy authelia:9091
}

